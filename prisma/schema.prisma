datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

// --- Models ---

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role          String  @default("VENDEDOR")
  accessLevel   String  @default("USER")
  organizationId String?
  branchId       String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  branch       Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([branchId])
}

model Customer {
  id           String    @id @default(cuid())
  name         String
  phone        String    @unique
  street       String
  number       String
  complement   String?
  neighborhood String
  reference     String?
  cep           String?
  city          String  @default("Lavras")
  branchId      String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  orders Order[]
  debts  Debt[]

  @@index([phone])
  @@index([name])
  @@index([branchId])
}

model Product {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  price       Float
  cost        Float
  category    String
  stockKind   String
  inventory   Int       @default(0)
  branchId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch             Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  orderItems         OrderItem[]
  inventoryMovements InventoryMovement[]
  butaneCylinders    ButaneCylinder[]

  @@index([branchId])
}

model ButaneCylinder {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  status    String
  branchId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([branchId])
}

model InventoryMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  type      String
  branchId  String?
  createdAt DateTime @default(now())

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([branchId])
}

model Order {
  id            String    @id @default(cuid())
  customerId    String
  customer      Customer  @relation(fields: [customerId], references: [id])
  status        String    @default("PENDENTE")
  paymentMethod String
  paymentDueDate DateTime?
  deliveryAddress String?
  deliveryReference String?
  deliveryAddressChanged Boolean @default(false)
  grossValue    Float
  totalCost     Float
  netValue      Float
  branchId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  items    OrderItem[]
  delivery Delivery?
  debt     Debt?

  @@index([branchId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  total     Float

  @@index([orderId])
}

model Delivery {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String   @default("PENDENTE")
  branchId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([branchId])
}

model Debt {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  value      Float
  dueDate    DateTime
  originalDueDate DateTime?
  paidAt     DateTime?
  renegotiatedAt DateTime?
  renegotiatedValue Float?
  notes      String?
  status     String   @default("PENDENTE")
  branchId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([status])
  @@index([branchId])
}

model Expense {
  id          String   @id @default(cuid())
  description String
  category    String
  subCategory String?
  value       Float
  date        DateTime
  paymentMethod String?
  responsible String?
  vehicleLabel String?
  isRecurring Boolean  @default(false)
  branchId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([branchId])
}

model Vehicle {
  id           String  @id @default(cuid())
  placa        String  @unique
  modelo       String
  tipo         String
  status       String
  custoMedioKm Float
  observacoes  String?
  branchId     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([branchId])
}



model DailyClosing {
  id             String   @id @default(cuid())
  date           DateTime
  totalSales     Decimal  @default(0)
  totalExpenses  Decimal  @default(0)
  totalRevenue   Decimal  @default(0)
  ordersCount    Int      @default(0)
  netBalance     Decimal  @default(0)
  notes          String?
  closedBy       String?
  branchId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([branchId])
}


model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  document  String?
  status    String   @default("ATIVA")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches Branch[]
  users    User[]

  @@index([status])
}

model Branch {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  tradingName    String?
  document       String?
  phone          String?
  city           String?
  status         String   @default("ATIVA")
  contractStatus String   @default("PROPRIA")
  planName       String?
  contractDueAt  DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users User[]
  customers Customer[]
  products Product[]
  butaneCylinders ButaneCylinder[]
  inventoryMovements InventoryMovement[]
  orders Order[]
  deliveries Delivery[]
  debts Debt[]
  expenses Expense[]
  vehicles Vehicle[]
  dailyClosings DailyClosing[]

  @@index([organizationId])
  @@index([status])
  @@index([contractStatus])
}
